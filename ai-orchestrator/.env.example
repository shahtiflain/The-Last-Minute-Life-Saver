# AI Orchestrator Environment Configuration

# 1. Google Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Internal API Key (For service-to-service auth)
INTERNAL_API_KEY=your_secure_internal_key

# 3. MongoDB Connection String (Atlas Serverless)
MONGO_URI=your_mongodb_connection_string_here
# 4. Firebase Service Account JSON (For Push Notifications)
# Path to the downloaded serviceAccountKey.json
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# 5. Environment (dev | prod)
ENV=dev

# 6. Google Calendar API OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
